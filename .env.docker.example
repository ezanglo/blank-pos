# Copy this file to `.env.docker` (gitignored), then run:
#   docker compose --env-file .env.docker up -d --build
#
# DATABASE_URL for containers uses hostname `postgres` inside Compose (see docker-compose.yml).
# From the host: localhost:5433 (fixed in docker-compose.yml).
# Optional cloud uploads (docs/storage-uploads.md):

BETTER_AUTH_SECRET=change-this-local-docker-only-placeholder-not-secret-enough-for-prod

BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

STORAGE_MODE=local

# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=
# STORAGE_FORCE_PATH_STYLE=true
# STORAGE_PUBLIC_URL_BASE=
