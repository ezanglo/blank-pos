# Postgres (Supabase pooler or direct)
DATABASE_URL=

# better-auth (min 32 chars)
BETTER_AUTH_SECRET=
# Public URL of the app (same origin as the browser uses)
BETTER_AUTH_URL=http://localhost:3000

# Optional: client-side absolute URL fallback (e.g. server actions / auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (optional until Storage / RLS work)
NEXT_PUBLIC_SUPABASE_URL=
# Dashboard → Settings → API Keys → Publishable key (sb_publishable_…). Legacy anon JWT still works if set instead.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Set to 1 only for CI/typecheck without real secrets
# SKIP_ENV_VALIDATION=1
