# Copy to `.env` and/or `.env.local` for local development (Next.js / Drizzle CLI).
#
# Docker Compose stack: copy `.env.docker.example` → `.env.docker` instead.

# PostgreSQL — any standard URL (local, Docker, Neon, RDS, pooler for serverless, etc.)
# Docker Compose (host port defaults to 5433 — see docker-compose.yml): postgresql://postgres:postgres@localhost:5433/blankpos
DATABASE_URL=

# better-auth (min 32 chars)
BETTER_AUTH_SECRET=
# Public URL of the app (same origin as the browser uses)
BETTER_AUTH_URL=http://localhost:3000

# Optional: client-side absolute URL fallback (e.g. server actions / auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Image uploads (see docs/storage-uploads.md) ---
# local = write under public/uploads (do not use on Vercel production)
# Omit or cloud = S3-compatible API (required on Vercel)
STORAGE_MODE=local

# Cloud object storage (S3, R2, MinIO, etc.) — required when STORAGE_MODE is not local
# STORAGE_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=auto
# STORAGE_FORCE_PATH_STYLE=true
# STORAGE_PUBLIC_URL_BASE=https://pub-xxx.r2.dev

# Set to 1 only for CI/typecheck without real secrets
# SKIP_ENV_VALIDATION=1
